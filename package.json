{
  "name": "sync",
  "version": "0.19.5-beta.2",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:installer": "set CARGO_TARGET_DIR=target-installer&& tauri build",
    "preview": "vite preview",
    "dev:stop-windivert": "sc stop windivert 2>NUL & npm run dev",
    "build:stop-windivert": "sc stop windivert 2>NUL & npm run build",
    "build:installer:stop-windivert": "sc stop windivert 2>NUL & set CARGO_TARGET_DIR=target-installer&& tauri build",
    "sync:meter-data": "node scripts/regenerate_meter_data_from_zdps.cjs ../BPSR-ZDPS-src/BPSR-ZDPS",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check:rust": "cargo check --all-targets --manifest-path src-tauri/Cargo.toml",
    "check:rust:strict": "cargo check --all-targets --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:all": "npm run check && npm run lint && npm run check:rust:strict",
    "tauri": "tauri",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint ."
  },
  "license": "MIT",
  "dependencies": {
    "@tanstack/table-core": "^8.21.3",
