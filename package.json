    "@tauri-store/svelte": "^3.1.0",
    "colorjs.io": "^0.5.2",
    "html2canvas-pro": "^1.5.11",
    "marked": "^17.0.0",
    "svelte-sonner": "^1.0.5",
    "tailwindcss": "^4.1.13",
    "tippy.js": "^6.3.7"
  },
